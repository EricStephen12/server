# 🌐 Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=
CLIENT_URL=

# 🗄️ Database (Neon/Postgres)
# Get this from your Neon dashboard
DATABASE_URL=

# 🔐 Authentication (Clerk)
# Get from https://dashboard.clerk.com → API Keys → Secret Key
CLERK_SECRET_KEY=sk_live_...

# 🧠 AI Services (Groq)
GROQ_API_KEY=

# ⚡ Cache (Upstash Redis — optional but recommended)
# Get a free Redis at https://upstash.com → Create Database → Copy "REDIS_URL"
# Without this, falls back to in-memory cache (works but resets on restart)
REDIS_URL=rediss://default:...@...upstash.io:6379

# 🛡️ Security & Sessions
# Used for custom JWT verification and Admin routes
JWT_SECRET=your_super_secret_jwt_key
ADMIN_PASSWORD=your_secure_admin_password
NEXTAUTH_SECRET=your_nextauth_secret_for_debug

# ❄️ Polar.sh Configuration
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# 🎵 Music Recognition
RAPIDAPI_SHAZAM_KEY=
