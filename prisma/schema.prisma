generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                            String?
  email                                           String?           @unique
  emailVerified                                   DateTime?         @map("email_verified") @db.Timestamptz(6)
  image                                           String?
  password                                        String?
  subscriptionTier                                String?           @default("free") @map("subscription_tier")
  creditsRemaining                                Int?              @default(10) @map("credits_remaining")
  createdAt                                       DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  totalScripts                                    Int?              @default(0) @map("total_scripts")
  totalPins                                       Int?              @default(0) @map("total_pins")
  totalVideosAnalyzed                             Int?              @default(0) @map("total_videos_analyzed")
  subscriptionStatus                              String?           @default("inactive") @map("subscription_status")
  paddle_customer_id                              String?
  next_billing_date                               DateTime?         @db.Timestamptz(6)
  updated_at                                      DateTime?         @default(now()) @db.Timestamptz(6)
  isAdmin                                         Boolean?          @default(false) @map("is_admin")
  clerkId                                         String?           @unique @map("clerk_id")
  onboardingCompleted                             Boolean?          @default(false) @map("onboarding_completed")
  brandNiche                                      String?           @map("brand_niche")
  primaryGoal                                     String?           @map("primary_goal")
  source                                          String?
  accounts                                        Account[]
  payments                                        payments[]
  scan_events                                     ScanEvent[]
  sessions                                        Session[]
  support_tickets                                 support_tickets[]
  team_members_team_members_member_user_idTousers TeamMember[]      @relation("team_members_member_user_idTousers")
  teamMembers                                     TeamMember[]      @relation("OwnerToMembers")

  @@map("users")
}

model TeamMember {
  id                                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId                                  String    @map("owner_id") @db.Uuid
  memberEmail                              String    @map("member_email")
  member_user_id                           String?   @db.Uuid
  role                                     String?   @default("member")
  status                                   String?   @default("pending")
  invited_at                               DateTime? @default(now()) @db.Timestamptz(6)
  joined_at                                DateTime? @db.Timestamptz(6)
  users_team_members_member_user_idTousers User?     @relation("team_members_member_user_idTousers", fields: [member_user_id], references: [id], onUpdate: NoAction)
  owner                                    User      @relation("OwnerToMembers", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ownerId, memberEmail])
  @@map("team_members")
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  userId            String  @map("user_id") @db.Uuid
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Ad {
  id            BigInt    @id @default(autoincrement())
  title         String
  niche         String?
  videoUrl      String    @map("video_url")
  thumbnailUrl  String?   @map("thumbnail_url")
  viewsCount    String?   @map("views_count")
  likesCount    String?   @map("likes_count")
  commentsCount String?   @map("comments_count")
  platform      String?   @default("tiktok")
  isVerified    Boolean?  @default(false) @map("is_verified")
  visualDna     Json?     @map("visual_dna")
  analysis      Json?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("ads")
}

model Script {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  title         String?
  scriptContent Json?     @map("script_content")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("scripts")
}

model LoungeSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  title     String?
  videoUrl  String?   @map("video_url")
  dna       Json?
  messages  Json?     @default("[]")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("lounge_sessions")
}

model ScanEvent {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  users     User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt], map: "idx_scan_events_user_created")
  @@map("scan_events")
}

model ad_benchmarks {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String?   @db.Uuid
  video_url          String?
  niche              String?
  hook_power         Decimal?  @db.Decimal(3, 1)
  retention_score    Decimal?  @db.Decimal(3, 1)
  conversion_trigger Decimal?  @db.Decimal(3, 1)
  awareness_level    String?
  style              String?
  primary_trigger    String?
  has_face           Boolean?  @default(false)
  has_text_overlay   Boolean?  @default(false)
  transcript_length  Int?      @default(0)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_benchmarks_created")
  @@index([niche], map: "idx_benchmarks_niche")
}

model payments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  email      String?
  amount     Int?
  plan       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model support_tickets {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  email      String?
  subject    String
  message    String
  status     String?   @default("open")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}


model Waitlist {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  platform  String   @default("unknown")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}

model SystemSettings {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}
